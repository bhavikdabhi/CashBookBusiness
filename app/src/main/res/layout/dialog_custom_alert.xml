<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp"
        android:orientation="vertical"
        android:background="@drawable/bg_popup_menu"
        android:elevation="@dimen/_6sdp"
        android:gravity="center_horizontal"
        android:clipToOutline="true">

        <!-- Icon Container -->
        <FrameLayout
            android:id="@+id/layoutIconContainer"
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:visibility="gone">

            <!-- Glow Background circle -->
            <View
                android:id="@+id/viewIconGlow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.15"
                android:background="@drawable/bg_auth_glow" />

            <!-- The Icon itself -->
            <ImageView
                android:id="@+id/ivDialogIcon"
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_help_qustionmark"
                app:tint="@color/primary_color" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/white"
            android:textSize="@dimen/_15ssp"
            android:gravity="center"
            android:text="Title Here"
            android:visibility="gone" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvDialogMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:fontFamily="@font/roboto_medium"
            android:textColor="@color/gray"
            android:textSize="@dimen/_12ssp"
            android:gravity="center"
            android:text="This is the message of the dialog."
            android:visibility="gone" />

        <!-- Buttons Container -->
        <LinearLayout
            android:id="@+id/layoutButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:orientation="horizontal"
            android:gravity="end"
            android:visibility="gone">

            <!-- Negative Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNegative"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/_38sdp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/gray"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_11ssp"
                app:strokeColor="@color/gray"
                app:cornerRadius="@dimen/_8sdp"
                android:visibility="gone" />

            <!-- Spacer between negative and positive buttons if both are gone -->
            <View
                android:id="@+id/btnSpacer"
                android:layout_width="@dimen/_8sdp"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- Positive Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPositive"
                android:layout_width="0dp"
                android:layout_height="@dimen/_38sdp"
                android:layout_weight="1"
                android:text="Confirm"
                android:textColor="@color/white"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_11ssp"
                app:backgroundTint="@color/primary_color"
                app:cornerRadius="@dimen/_8sdp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Neutral Button (Full Width, below the horizontal buttons, in case it is needed) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNeutral"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="Neutral Action"
            android:textColor="@color/primary_color"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_11ssp"
            android:visibility="gone" />

    </LinearLayout>
</FrameLayout>
