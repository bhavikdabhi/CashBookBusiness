<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_20sdp"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:elevation="@dimen/_6sdp"
        android:clipToOutline="true">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Member"
        android:textSize="@dimen/_16ssp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:textFontWeight="600"
        android:layout_marginBottom="@dimen/_12sdp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/GlassInput"
        android:hint="Phone Number (10 digits)"
        android:layout_marginBottom="@dimen/_12sdp"
        android:textColorHint="@color/gray">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMemberPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_color"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:inputType="phone"
            android:maxLength="10"/>

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvRoleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Role"
        android:fontFamily="@font/roboto_regular"
        android:textFontWeight="600"
        android:textSize="@dimen/_13ssp"
        android:layout_marginBottom="@dimen/_6sdp"/>

    <RadioGroup
        android:id="@+id/rgRoles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/text_color"
            android:text="Admin (Manage All except business)"
            android:visibility="gone"/>

        <RadioButton
            android:id="@+id/rbPartner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/text_color"
            android:text="Partner (Full Access, No Delete Business)"
            android:visibility="gone"/>

        <RadioButton
            android:id="@+id/rbWriter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/text_color"
            android:text="Writer (Add/Remove Transactions)"
            android:visibility="gone"/>

        <RadioButton
            android:id="@+id/rbReader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reader (View Only)"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/text_color"
            android:visibility="gone"/>

    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddMember"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:fontFamily="@font/roboto_bold"
        android:textFontWeight="600"
        android:text="Add Member"
        android:textAllCaps="false"
        android:textSize="@dimen/_14ssp"
        android:textColor="@color/text_color"
        app:backgroundTint="@color/primary_color"
        app:cornerRadius="@dimen/_12sdp"
        style="@style/Widget.MaterialComponents.Button" />


</LinearLayout>
</FrameLayout>