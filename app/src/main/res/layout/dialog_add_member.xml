<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:elevation="@dimen/_6sdp"
        android:clipToOutline="true">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Member"
        android:textSize="@dimen/_16ssp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        android:textFontWeight="600"
        android:layout_marginBottom="@dimen/_12sdp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/GlassInput"
        android:hint="Phone Number (10 digits)"
        android:layout_marginBottom="@dimen/_12sdp"
        android:textColorHint="@color/gray">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMemberPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:inputType="phone"
            android:maxLength="10"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilRole"
        style="@style/GlassInput.ExposedDropdownMenu"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Select Role"
        android:layout_marginBottom="@dimen/_12sdp"
        android:textColorHint="@color/gray">

        <AutoCompleteTextView
            android:id="@+id/actvRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/roboto_regular"
            android:textFontWeight="600"
            android:textSize="@dimen/_12ssp"
            android:inputType="none"
            android:popupBackground="@drawable/bg_dropdown_popup"/>

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddMember"
        android:layout_marginTop="@dimen/_20sdp"
        android:textFontWeight="600"
        android:text="Add Member"
        android:textAllCaps="false"
        android:textSize="@dimen/_14ssp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:fontFamily="@font/roboto_bold"
        android:textColor="@color/auth_bg"
        android:elevation="@dimen/_16sdp"
        android:background="@drawable/bg_gradient_button"
        app:cornerRadius="@dimen/_12sdp" />

</LinearLayout>
</FrameLayout>