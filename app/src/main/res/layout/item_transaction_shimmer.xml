<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_bg"
        android:layout_marginTop="@dimen/_5sdp"
        app:cardCornerRadius="@dimen/_12sdp"
        app:contentPaddingLeft="@dimen/_10sdp"
        app:contentPaddingRight="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_3sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="@dimen/_1sdp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/_10sdp">

            <!-- Party Name Placeholder -->
            <View
                android:id="@+id/placeholderParty"
                android:layout_width="@dimen/_120sdp"
                android:layout_height="@dimen/_14sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Amount Placeholder -->
            <View
                android:id="@+id/placeholderAmount"
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_14sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Remark Placeholder -->
            <View
                android:id="@+id/placeholderRemark"
                android:layout_width="@dimen/_180sdp"
                android:layout_height="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/placeholderParty" />

            <!-- Balance Placeholder -->
            <View
                android:id="@+id/placeholderBalance"
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/placeholderAmount" />

            <!-- Category chip Placeholder -->
            <View
                android:id="@+id/placeholderCategory"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_18sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/placeholderRemark" />

            <View
                android:id="@+id/lineDivider"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:background="@color/glass_border"
                app:layout_constraintTop_toBottomOf="@id/placeholderCategory" />

            <!-- Entry Info Placeholder -->
            <View
                android:id="@+id/placeholderEntryInfo"
                android:layout_width="@dimen/_140sdp"
                android:layout_height="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/bg_shimmer_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lineDivider" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
