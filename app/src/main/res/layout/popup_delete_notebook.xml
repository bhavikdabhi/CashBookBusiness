<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/_260sdp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="@dimen/_16sdp"
    android:background="@drawable/bg_popup_menu">

    <!-- Top Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete Notebook"
            android:fontFamily="@font/roboto_bold"
            android:textFontWeight="600"
            android:textSize="@dimen/_16ssp"
            android:textColor="@color/text_secondary" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary" />
    </RelativeLayout>

    <!-- Notebook Name -->
    <TextView
        android:id="@+id/tvNotebookName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:fontFamily="@font/roboto_medium"
        android:textFontWeight="600"
        android:text="Notebook Name"
        android:textColor="@color/text_disabled" />

    <!-- Warning -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This will permanently delete this notebook and its data."
        android:textColor="@color/text_entryBy"
        android:fontFamily="@font/roboto_regular"
        android:textFontWeight="600"
        android:layout_marginTop="@dimen/_4sdp" />

    <!-- Delete Button -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:fontFamily="@font/roboto_bold"
        android:textFontWeight="600"
        android:textAllCaps="false"
        android:textSize="@dimen/_14ssp"
        android:gravity="center"
        android:text="Delete"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/primary_color"
        app:cornerRadius="@dimen/_12sdp"
        style="@style/DangerButton"  />

</LinearLayout>
