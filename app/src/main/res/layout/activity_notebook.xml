<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    tools:context=".ui.notebook.NotebookActivity">

    <!-- TOP BAR -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_12sdp"
        android:background="@drawable/bg_glass_card"
        android:elevation="@dimen/_6sdp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notebook Name"
                android:fontFamily="@font/roboto_medium"
                android:textFontWeight="600"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold"
                android:textColor="@color/text_color"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_regular"
                android:textFontWeight="600"
                android:text="Members"
                android:textSize="@dimen/_10ssp"
                android:textColor="@color/text_entryBy"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:src="@drawable/icon_threedots"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="@dimen/_6sdp"
            app:tint="@color/text_color"/>

        <ImageButton
            android:id="@+id/btn_pdf"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:src="@drawable/ic_book"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_toStartOf="@id/btn_menu"
            android:layout_centerVertical="true"
            android:padding="@dimen/_6sdp"
            app:tint="@color/primary_color"/>

    </RelativeLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="@dimen/_10sdp"
        android:background="@drawable/bg_glass_card"
        android:elevation="@dimen/_8sdp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cash_in"
            android:layout_width="0dp"
            android:layout_height="@dimen/_48sdp"
            android:layout_weight="1"
            android:text="+ CASH IN"
            android:fontFamily="@font/roboto_bold"
            android:textFontWeight="600"
            android:textSize="@dimen/_14ssp"
            app:backgroundTint="@color/success"
            app:cornerRadius="@dimen/_12sdp"
            android:layout_marginEnd="@dimen/_8sdp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cash_out"
            android:layout_width="0dp"
            android:layout_height="@dimen/_48sdp"
            android:layout_weight="1"
            android:text="- CASH OUT"
            android:fontFamily="@font/roboto_bold"
            android:textFontWeight="600"
            android:textSize="@dimen/_14ssp"
            app:backgroundTint="@color/danger"
            app:cornerRadius="@dimen/_12sdp"
            android:layout_marginStart="@dimen/_8sdp"/>

    </LinearLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar"
        android:layout_above="@id/bottom_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_12sdp">

            <!-- FILTER CHIPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/_5sdp">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filter"
                    android:fontFamily="@font/roboto_regular"
                    android:textFontWeight="600"
                    app:chipIcon="@drawable/ic_filter_list"
                    app:chipBackgroundColor="@color/card_bg"
                    app:chipIconTint="@color/text_color"
                    android:textColor="@color/text_color"/>

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Date"
                    android:fontFamily="@font/roboto_regular"
                    android:textFontWeight="600"
                    android:layout_marginStart="@dimen/_8sdp"
                    app:chipBackgroundColor="@color/card_bg"
                    android:textColor="@color/text_color"/>
            </LinearLayout>

            <!-- SUMMARY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="@dimen/_1sdp"
                app:cardCornerRadius="@dimen/_14sdp"
                app:contentPaddingRight="@dimen/_16sdp"
                app:contentPaddingLeft="@dimen/_16sdp"
                app:contentPaddingTop="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_12sdp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_8sdp">

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="Net Balance"
                            android:textStyle="bold"
                            android:textSize="@dimen/_14ssp"
                            android:fontFamily="@font/roboto_regular"
                            android:textFontWeight="600"
                            android:textColor="@color/text_color"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tv_net_balance"
                            android:text="0"
                            android:fontFamily="@font/roboto_regular"
                            android:textFontWeight="600"
                            android:textStyle="bold"
                            android:textSize="@dimen/_14ssp"
                            android:textColor="@color/text_color"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/glass_border"
                        android:layout_marginBottom="@dimen/_8sdp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Total In (+)"
                        android:fontFamily="@font/roboto_regular"
                        android:textFontWeight="600"
                        android:textStyle="bold"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/text_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tv_total_in"
                        android:fontFamily="@font/roboto_regular"
                        android:textFontWeight="600"
                        android:text="Total In: 0"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/success"/>


                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Total Out (-)"
                        android:fontFamily="@font/roboto_regular"
                        android:textFontWeight="600"
                        android:textStyle="bold"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/text_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tv_total_out"
                        android:text="Total Out: 0"
                        android:fontFamily="@font/roboto_regular"
                        android:textFontWeight="600"
                        android:textColor="@color/danger"
                        android:textSize="@dimen/_12ssp"
                        android:layout_marginBottom="@dimen/_12sdp"/>
                </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/glass_border"
                        android:layout_marginBottom="@dimen/_2sdp"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIEW REPORTS >"
                        android:fontFamily="@font/roboto_bold"
                        android:textFontWeight="600"
                        android:textSize="@dimen/_10ssp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/primary_color"
                        android:layout_gravity="center"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tv_entries_count"
                android:text="Showing 0 entries"
                android:textSize="@dimen/_10ssp"
                android:fontFamily="@font/roboto_regular"
                android:textFontWeight="600"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="@dimen/_2sdp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/transactions_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
