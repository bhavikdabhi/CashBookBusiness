<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_40sdp">

        <!-- ──── TOOLBAR SECTION ──── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="@dimen/_12sdp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="@dimen/_36sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notebook Settings"
                android:textColor="@color/white"
                android:fontFamily="@font/roboto_medium"
                android:textSize="@dimen/_16ssp"
                android:layout_marginStart="@dimen/_8sdp"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageButton
                android:id="@+id/btn_overflow_menu"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="@dimen/_36sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_expand_more"
                android:rotation="90"
                app:tint="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ──── GENERAL IDENTITY SECTION ──── -->
        <TextView
            android:id="@+id/lbl_general_identity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GENERAL IDENTITY"
            android:textColor="@color/gray"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_9ssp"
            android:letterSpacing="0.1"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/layout_header"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_identity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:background="@drawable/bg_glass_card"
            android:padding="@dimen/_20sdp"
            app:layout_constraintTop_toBottomOf="@id/lbl_general_identity">

            <TextView
                android:id="@+id/lbl_notebook_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTEBOOK NAME"
                android:textColor="@color/gray"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_8ssp"
                android:letterSpacing="0.05"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/et_notebook_name"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_48sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/roboto_regular"
                android:hint="Enter notebook name"
                android:paddingHorizontal="@dimen/_16sdp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray"
                android:textSize="@dimen/_12ssp"
                app:layout_constraintTop_toBottomOf="@id/lbl_notebook_name" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_48sdp"
                android:layout_marginTop="@dimen/_16sdp"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_13ssp"
                app:cornerRadius="@dimen/_12sdp"
                app:backgroundTint="@color/primary_color"
                app:layout_constraintTop_toBottomOf="@id/et_notebook_name" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ──── MANAGEMENT SECTION ──── -->
        <TextView
            android:id="@+id/lbl_management"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MANAGEMENT"
            android:textColor="@color/gray"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_9ssp"
            android:letterSpacing="0.1"
            android:layout_marginTop="@dimen/_24sdp"
            android:layout_marginStart="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/card_identity"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_management_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/lbl_management">

            <!-- Partners Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnManageMembers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_6sdp"
                android:background="@drawable/bg_glass_card"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_partners_icon"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:background="@drawable/bg_input_field"
                    android:padding="@dimen/_8sdp"
                    android:src="@drawable/ic_action_group"
                    app:tint="#4DB6AC"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_members_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:fontFamily="@font/roboto_bold"
                    android:textSize="@dimen/_20ssp"
                    android:layout_marginTop="@dimen/_16sdp"
                    app:layout_constraintTop_toBottomOf="@id/iv_partners_icon"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Members"
                    android:textColor="@color/gray"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="@dimen/_9ssp"
                    app:layout_constraintTop_toBottomOf="@id/tv_members_count"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Classes Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnManageCategories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_6sdp"
                android:background="@drawable/bg_glass_card"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_classes_icon"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:background="@drawable/bg_input_field"
                    android:padding="@dimen/_8sdp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="#81D4FA"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_classes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:fontFamily="@font/roboto_bold"
                    android:textSize="@dimen/_20ssp"
                    android:layout_marginTop="@dimen/_16sdp"
                    app:layout_constraintTop_toBottomOf="@id/iv_classes_icon"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ledger Classes"
                    android:textColor="@color/gray"
                    android:fontFamily="@font/roboto_regular"
                    android:textSize="@dimen/_9ssp"
                    app:layout_constraintTop_toBottomOf="@id/tv_classes_count"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <!-- ──── UTILITY ACTIONS SECTION ──── -->
        <TextView
            android:id="@+id/lbl_utility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTILITY ACTIONS"
            android:textColor="@color/gray"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_9ssp"
            android:letterSpacing="0.1"
            android:layout_marginTop="@dimen/_24sdp"
            android:layout_marginStart="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/layout_management_grid"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnDuplicateNotebook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:background="@drawable/bg_glass_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/lbl_utility">

            <ImageView
                android:id="@+id/iv_duplicate_icon"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="@dimen/_36sdp"
                android:background="@drawable/bg_input_field"
                android:padding="@dimen/_8sdp"
                android:src="@android:drawable/ic_menu_set_as"
                app:tint="@color/gray"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_duplicate_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duplicate Notebook"
                android:textColor="@color/white"
                android:fontFamily="@font/roboto_medium"
                android:textSize="@dimen/_13ssp"
                android:layout_marginStart="@dimen/_16sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_duplicate_icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Clone all entries and settings to a new book"
                android:textColor="@color/gray"
                android:fontFamily="@font/roboto_regular"
                android:textSize="@dimen/_10ssp"
                android:layout_marginTop="@dimen/_1sdp"
                app:layout_constraintTop_toBottomOf="@id/tv_duplicate_title"
                app:layout_constraintStart_toStartOf="@id/tv_duplicate_title"
                app:layout_constraintEnd_toStartOf="@id/iv_chevron" />

            <ImageView
                android:id="@+id/iv_chevron"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/gray"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ──── DANGER ZONE SECTION ──── -->
        <TextView
            android:id="@+id/lbl_danger_zone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DANGER ZONE"
            android:textColor="#FFB3B3"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_9ssp"
            android:letterSpacing="0.1"
            android:layout_marginTop="@dimen/_24sdp"
            android:layout_marginStart="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/btnDuplicateNotebook"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_danger_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:background="@drawable/bg_danger_zone"
            android:padding="@dimen/_20sdp"
            app:layout_constraintTop_toBottomOf="@id/lbl_danger_zone">

            <ImageView
                android:id="@+id/iv_danger_icon"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="#FFB3B3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_danger_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete this notebook"
                android:textColor="#FFB3B3"
                android:fontFamily="@font/roboto_medium"
                android:textSize="@dimen/_14ssp"
                android:layout_marginStart="@dimen/_12sdp"
                app:layout_constraintTop_toTopOf="@id/iv_danger_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_danger_icon"
                app:layout_constraintStart_toEndOf="@id/iv_danger_icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Once you delete a notebook, there is no going back. All financial data will be permanently purged."
                android:textColor="#CC8888"
                android:fontFamily="@font/roboto_regular"
                android:textSize="@dimen/_11ssp"
                android:layout_marginTop="@dimen/_8sdp"
                app:layout_constraintTop_toBottomOf="@id/iv_danger_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteBusiness"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_48sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:text="Delete Notebook"
                android:textAllCaps="false"
                android:textColor="#FFB3B3"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_13ssp"
                app:cornerRadius="@dimen/_12sdp"
                app:strokeColor="#FFB3B3"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tv_danger_title"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                <!-- Note: The anchor above is wrong, fixing below -->

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
