<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
style="@style/Widget.App.GlassCard"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="@dimen/_12sdp"
android:layout_marginHorizontal="@dimen/_20sdp"
android:clickable="true"
android:focusable="true">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/_16sdp">

    <!-- Avatar Circular -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_party_icon"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        android:src="@drawable/ic_action_group"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Delete Action -->
    <ImageButton
        android:id="@+id/iv_delete"
        android:layout_width="@dimen/_32sdp"
        android:layout_height="@dimen/_32sdp"
        android:src="@drawable/ic_action_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="@dimen/_8sdp"
        app:tint="@color/auth_text_light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Priority Tag -->
    <TextView
        android:id="@+id/tvPriorityTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRIMARY PARTNER"
        android:fontFamily="@font/roboto_bold"
        android:textColor="@color/auth_glow_2"
        android:textSize="@dimen/_8ssp"
        android:background="@drawable/bg_badge_active"
        android:paddingHorizontal="@dimen/_8sdp"
        android:paddingVertical="@dimen/_4sdp"
        android:layout_marginTop="@dimen/_12sdp"
        app:layout_constraintTop_toBottomOf="@id/iv_party_icon"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Name Content -->
    <TextView
        android:id="@+id/tv_party_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Party Name Logistics"
        android:fontFamily="@font/roboto_bold"
        android:textColor="@android:color/white"
        android:textSize="@dimen/_16ssp"
        android:layout_marginTop="@dimen/_6sdp"
        app:layout_constraintTop_toBottomOf="@id/tvPriorityTag"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contact Info -->
    <LinearLayout
        android:id="@+id/layoutContact"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/_4sdp"
        app:layout_constraintTop_toBottomOf="@id/tv_party_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivContactIcon"
            android:layout_width="@dimen/_12sdp"
            android:layout_height="@dimen/_12sdp"
            android:src="@drawable/ic_book"
            app:tint="@color/auth_text_light" />

        <TextView
            android:id="@+id/tvContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="contact@email.com"
            android:fontFamily="@font/roboto_regular"
            android:textColor="@color/auth_text_light"
            android:textSize="@dimen/_10ssp"
            android:layout_marginStart="@dimen/_6sdp" />
    </LinearLayout>

    <View
        android:id="@+id/ViewLine"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:background="@color/glass_border"
        android:layout_marginTop="@dimen/_12sdp"
        app:layout_constraintTop_toBottomOf="@+id/layoutContact" />
    <!-- Footer Row -->
    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/ViewLine"
        tools:layout_editor_absoluteX="21dp">

        <TextView
            android:id="@+id/tv_party_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_bold"
            android:letterSpacing="0.05"
            android:text="ROLE: VENDOR"
            android:textColor="@color/auth_glow_2"
            android:textSize="@dimen/_9ssp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />


        <!-- Overlapping Members Mock -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:layout_marginStart="0dp"
                android:src="@drawable/bg_auth_glow"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:layout_marginStart="@dimen/_10sdp"
                android:src="@drawable/bg_primary_gradient"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>


