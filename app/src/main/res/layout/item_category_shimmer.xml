<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.App.GlassCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_12sdp"
    android:layout_marginHorizontal="@dimen/_20sdp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp">

        <!-- Icon Box Placeholder -->
        <View
            android:id="@+id/placeholderIcon"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            android:background="@drawable/bg_shimmer_placeholder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Name Content Placeholder -->
        <View
            android:id="@+id/placeholderName"
            android:layout_width="@dimen/_180sdp"
            android:layout_height="@dimen/_16sdp"
            android:background="@drawable/bg_shimmer_placeholder"
            android:layout_marginTop="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/placeholderIcon"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Description Placeholder -->
        <View
            android:id="@+id/placeholderDescription"
            android:layout_width="@dimen/_220sdp"
            android:layout_height="@dimen/_11sdp"
            android:background="@drawable/bg_shimmer_placeholder"
            android:layout_marginTop="@dimen/_6sdp"
            app:layout_constraintTop_toBottomOf="@id/placeholderName"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Utilization Footer Placeholder -->
        <View
            android:id="@+id/placeholderUtilization"
            android:layout_width="@dimen/_80sdp"
            android:layout_height="@dimen/_8sdp"
            android:background="@drawable/bg_shimmer_placeholder"
            android:layout_marginTop="@dimen/_20sdp"
            app:layout_constraintTop_toBottomOf="@id/placeholderDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/placeholderProgress"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/bg_shimmer_placeholder"
            android:layout_marginTop="@dimen/_6sdp"
            app:layout_constraintTop_toBottomOf="@id/placeholderUtilization" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
