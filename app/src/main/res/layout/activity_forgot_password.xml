<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/auth_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/_16sdp"
        android:translationZ="100dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/ic_cash_volate"
            app:tint="@color/auth_glow_2" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_weight="1"
            android:fontFamily="@font/roboto_bold"
            android:text="CashBook"
            android:textColor="@color/auth_glow_2"
            android:textSize="@dimen/_16ssp" />

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/ic_help_qustionmark"
            app:tint="@color/auth_glow_2" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgSmoke"
        android:layout_width="@dimen/_200sdp"
        android:layout_height="@dimen/_200sdp"
        android:src="@drawable/smoke_bg_top"
        android:layout_marginTop="-90dp"
        android:layout_marginStart="-90dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_header" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/_20sdp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:background="@drawable/bg_auth_card"
        android:padding="@dimen/_16sdp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ic_reset"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:background="@drawable/bg_input_field"
            android:src="@android:drawable/ic_popup_sync"
            android:padding="@dimen/_8sdp"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Password"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_24ssp"
            android:textColor="@color/auth_accent_light"
            android:layout_marginTop="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@id/ic_reset"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Enter your email address to receive a secure recovery link."
            android:textColor="@color/auth_text"
            android:fontFamily="@font/roboto_regular"
            android:textSize="@dimen/_11ssp"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginHorizontal="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/lbl_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:fontFamily="@font/roboto_regular"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/auth_text_light"
            android:layout_marginTop="@dimen/_20sdp"
            app:layout_constraintTop_toBottomOf="@id/tv_desc"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_40sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="@dimen/_16sdp"
            android:hint="ledger@ethereal.com"
            android:textColorHint="@color/dark_gray"
            android:textColor="@color/white"
            android:drawableStart="@drawable/ic_auth_email"
            android:drawablePadding="@dimen/_10sdp"
            android:drawableTint="@color/auth_text_light"
            android:inputType="textEmailAddress"
            android:fontFamily="@font/roboto_regular"
            android:textSize="@dimen/_12ssp"
            app:layout_constraintTop_toBottomOf="@id/lbl_email" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:text="Send Recovery Link \u2192"
            android:layout_height="@dimen/_45sdp"
            android:background="@drawable/bg_gradient_button"
            android:paddingEnd="@dimen/_16sdp"
            android:textColor="@color/auth_bg"
            android:fontFamily="@font/roboto_bold"
            android:textSize="@dimen/_13ssp"
            android:textAllCaps="false"
            android:elevation="@dimen/_16sdp"
            android:outlineAmbientShadowColor="@color/auth_glow_1"
            android:outlineSpotShadowColor="@color/auth_glow_1"
            android:layout_marginTop="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/et_email" />

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt; Back to Sign In"
            android:fontFamily="@font/roboto_regular"
            android:textColor="@color/auth_text_light"
            android:textSize="@dimen/_12ssp"
            android:layout_marginTop="@dimen/_30sdp"
            android:paddingBottom="@dimen/_8sdp"
            app:layout_constraintTop_toBottomOf="@id/btn_send"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="© 2026 CASHBOOKBUSINESS • SECURE FINANCIAL INFRASTRUCTURE"
        android:textSize="@dimen/_8ssp"
        android:fontFamily="@font/roboto_regular"
        android:textColor="@color/auth_text_light"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
