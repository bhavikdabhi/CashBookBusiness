<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="12dp"
    android:paddingStart="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- Icon -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/icon_card"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E3F2FD" 
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_action_group"
            app:tint="@color/primary_color"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/icon_card"
        app:layout_constraintEnd_toStartOf="@id/tv_balance"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/notebook_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="D@Bhi Family"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:ellipsize="end"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/notebook_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="6 Members . Updated on Oct 06"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- Balance -->
    <TextView
        android:id="@+id/tv_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="2,157"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/success"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/btn_notebook_options"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Menu -->
    <ImageButton
        android:id="@+id/btn_notebook_options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_threedots"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        app:tint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>