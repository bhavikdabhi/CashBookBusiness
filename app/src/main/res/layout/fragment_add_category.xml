<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_bg"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Premium Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/btnBack"
                android:fontFamily="@font/roboto_bold"
                android:text="NotebookName"
                android:textColor="@color/white"
                android:textSize="@dimen/_16ssp" />

<!--            <com.google.android.material.imageview.ShapeableImageView-->
<!--                android:id="@+id/iv_profile"-->
<!--                android:layout_width="32dp"-->
<!--                android:layout_height="32dp"-->
<!--                android:layout_alignParentEnd="true"-->
<!--                android:layout_centerVertical="true"-->
<!--                android:src="@drawable/ic_default_avtar"-->
<!--                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"-->
<!--                app:strokeColor="@color/glass_border"-->
<!--                app:strokeWidth="1dp" />-->

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_profile_pic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_avtar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    app:strokeColor="@color/auth_glow_1"
                    app:strokeWidth="2dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/_24sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_16sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Create Category"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/_16ssp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_6sdp"
                    android:alpha="0.6"
                    android:fontFamily="@font/roboto_regular"
                    android:text="Define a new bucket for your financial momentum."
                    android:textColor="@color/white"
                    android:textSize="@dimen/_12ssp" />

                <!-- CATEGORY NAME & TYPE CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_16sdp">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:letterSpacing="0.1"
                            android:text="Category Name"
                            android:textColor="@color/auth_glow_2"
                            android:textSize="@dimen/_12ssp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/etCategoryName"
                            android:layout_marginTop="@dimen/_6sdp"
                            style="@style/GlassInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. Marketing, Rent, Coffee"
                            android:textColorHint="@color/auth_text"
                            app:layout_constraintTop_toBottomOf="@id/lbl_full_name">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:inputType="textPersonName"
                                android:textSize="@dimen/_12ssp"
                                android:fontFamily="@font/roboto_regular"
                                android:textFontWeight="600"
                                />
                        </com.google.android.material.textfield.TextInputLayout>


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_12sdp"
                            android:fontFamily="@font/roboto_medium"
                            android:letterSpacing="0.1"
                            android:text="Transaction Type"
                            android:textColor="@color/auth_glow_2"
                            android:textSize="@dimen/_12ssp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_35sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeIncome"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/card_bg"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Income"
                                android:textColor="@color/white"
                                app:cornerRadius="@dimen/_14sdp"
                                app:icon="@drawable/ic_type_income"
                                app:iconGravity="textStart"
                                app:iconTint="@null"
                                app:strokeColor="@color/glass_border"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeExpense"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/card_bg"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Expense"
                                android:textColor="@color/danger"
                                app:cornerRadius="@dimen/_14sdp"
                                app:icon="@drawable/ic_type_expense"
                                app:iconGravity="textStart"
                                app:iconTint="@null"
                                app:strokeColor="@color/danger"
                                app:strokeWidth="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AESTHETIC TINT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_16sdp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:letterSpacing="0.1"
                            android:text="Aesthetic Tint"
                            android:textColor="@color/auth_glow_2"
                            android:textSize="@dimen/_12ssp" />

                        <GridLayout
                            android:id="@+id/colorGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:columnCount="5"
                            android:useDefaultMargins="true" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FINANCIAL GLYPH CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_12sdp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:letterSpacing="0.1"
                            android:text="Financial Glyph"
                            android:textColor="@color/auth_glow_2"
                            android:textSize="@dimen/_12ssp" />

                        <GridLayout
                            android:id="@+id/iconGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_12ssp"
                            android:columnCount="4"
                            android:useDefaultMargins="true" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.App.Button.Gradient"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:background="@drawable/bg_gradient_button"
                    android:elevation="@dimen/_16sdp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Create Category"
                    android:textAllCaps="false"
                    android:textColor="@color/auth_bg"
                    android:textSize="@dimen/_14ssp"
                    app:backgroundTint="@null"
                    app:cornerRadius="@dimen/_12sdp"
                    app:rippleColor="@null" />
            </LinearLayout>

        </ScrollView>

        <!-- Save Button Area -->
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
