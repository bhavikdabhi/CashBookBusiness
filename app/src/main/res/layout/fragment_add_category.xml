<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitch_background"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Premium Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/btnBack"
                android:fontFamily="@font/roboto_bold"
                android:text="Ethereal Ledger"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_default_avtar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="1dp" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Create Category"
                    android:textColor="@color/white"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.6"
                    android:fontFamily="@font/roboto_regular"
                    android:text="Define a new bucket for your financial momentum."
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <!-- CATEGORY NAME & TYPE CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="CATEGORY NAME"
                            android:textColor="@color/text_disabled"
                            android:textSize="12sp"
                            android:letterSpacing="0.1" />

                        <EditText
                            android:id="@+id/etCategoryName"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_glass_field"
                            android:fontFamily="@font/roboto_regular"
                            android:hint="e.g. Marketing, Rent, Coffee"
                            android:inputType="textCapWords"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/gray" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="TRANSACTION TYPE"
                            android:textColor="@color/text_disabled"
                            android:textSize="12sp"
                            android:letterSpacing="0.1" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeIncome"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/card_bg"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Income"
                                android:textColor="@color/white"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_type_income"
                                app:iconGravity="textStart"
                                app:iconTint="@null"
                                app:strokeColor="@color/glass_border"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeExpense"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/card_bg"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Expense"
                                android:textColor="@color/danger"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_type_expense"
                                app:iconGravity="textStart"
                                app:iconTint="@null"
                                app:strokeColor="@color/danger"
                                app:strokeWidth="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AESTHETIC TINT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="AESTHETIC TINT"
                            android:textColor="@color/text_disabled"
                            android:textSize="12sp"
                            android:letterSpacing="0.1" />

                        <GridLayout
                            android:id="@+id/colorGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:columnCount="5"
                            android:useDefaultMargins="true" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FINANCIAL GLYPH CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="FINANCIAL GLYPH"
                            android:textColor="@color/text_disabled"
                            android:textSize="12sp"
                            android:letterSpacing="0.1" />

                        <GridLayout
                            android:id="@+id/iconGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:columnCount="4"
                            android:useDefaultMargins="true" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.App.Button.Gradient"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="CREATE CATEGORY"
                    android:textColor="@color/stitch_background"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    app:rippleColor="@color/white" />
            </LinearLayout>
        </ScrollView>

        <!-- Save Button Area -->
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
