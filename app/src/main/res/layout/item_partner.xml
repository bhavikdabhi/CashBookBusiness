<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_glass_card">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/icon_card"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E3F2FD">

        <ImageView
            android:id="@+id/iv_partner_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_action_group"
            app:tint="@color/primary_color"/>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tv_partner_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Partner Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/tv_partner_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Partner"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_remove_partner"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_action_delete"
        app:tint="@android:color/holo_red_dark"
        android:padding="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"/>

</LinearLayout>