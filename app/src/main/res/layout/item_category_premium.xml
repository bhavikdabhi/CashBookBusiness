<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.App.GlassCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_12sdp"
    android:layout_marginHorizontal="@dimen/_20sdp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp">

        <!-- Icon Box -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIcon"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardElevation="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_book"
                app:tint="@color/auth_glow_2" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Delete Action -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:src="@drawable/ic_action_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/_8sdp"
            app:tint="@color/auth_text_light"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Text Content -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Category Name"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_16ssp"
            android:layout_marginTop="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/cardIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Short description of the category flow"
            android:fontFamily="@font/roboto_regular"
            android:textColor="@color/auth_text_light"
            android:textSize="@dimen/_11ssp"
            android:layout_marginTop="@dimen/_4sdp"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Utilization Footer -->
        <TextView
            android:id="@+id/lblUtilization"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTILIZATION"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/auth_text_light"
            android:textSize="@dimen/_8ssp"
            android:letterSpacing="0.1"
            android:layout_marginTop="@dimen/_20sdp"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvUtilizationPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:fontFamily="@font/roboto_bold"
            android:textColor="@color/auth_text_light"
            android:textSize="@dimen/_8ssp"
            app:layout_constraintTop_toTopOf="@id/lblUtilization"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressUtilization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6sdp"
            app:trackThickness="2dp"
            app:trackColor="#1AFFFFFF"
            app:indicatorColor="@color/auth_glow_2"
            app:trackCornerRadius="4dp"
            app:layout_constraintTop_toBottomOf="@id/lblUtilization"
            tools:progress="60" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
