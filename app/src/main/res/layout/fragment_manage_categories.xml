<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stitch_background"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_56sdp"
            android:paddingHorizontal="@dimen/_12sdp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/stitch_primary"
                android:padding="@dimen/_8sdp" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Business Finance"
                android:fontFamily="@font/roboto_medium"
                android:textSize="@dimen/_14ssp"
                android:textColor="@android:color/white" />
            
            <ImageButton
                android:id="@+id/btnToolbarAdd"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_gravity="center_vertical|end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add"
                app:tint="@android:color/white"
                android:padding="@dimen/_8sdp" />
        </FrameLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_40sdp">

                <!-- Header Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/_20sdp"
                    android:layout_marginTop="@dimen/_16sdp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edit Categories"
                        android:fontFamily="@font/roboto_bold"
                        android:textSize="@dimen/_28ssp"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Organize your financial flow by managing transaction categories. These will be reflected across your momentum reports."
                        android:fontFamily="@font/roboto_regular"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/stitch_on_surface_variant"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:lineSpacingExtra="2dp" />

                    <!-- Search + Create Box -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#0DFFFFFF"
                        app:cardElevation="0dp"
                        app:cardCornerRadius="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_24sdp"
                        android:padding="@dimen/_12sdp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/_12sdp">
                            
                            <!-- Search -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_36sdp"
                                android:background="@drawable/bg_input_field"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="@dimen/_12sdp">
                                <ImageView
                                    android:layout_width="@dimen/_16sdp"
                                    android:layout_height="@dimen/_16sdp"
                                    android:src="@drawable/ic_search"
                                    app:tint="@color/stitch_on_surface_variant" />
                                <EditText
                                    android:id="@+id/etSearch"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:hint="Search categories..."
                                    android:textColorHint="@color/stitch_on_surface_variant"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/_12ssp"
                                    android:layout_marginStart="@dimen/_8sdp"
                                    android:inputType="text" />
                            </LinearLayout>

                            <!-- Create Button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCreateCategory"
                                style="@style/Widget.App.Button.Gradient"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_42sdp"
                                android:layout_marginTop="@dimen/_12sdp"
                                android:text="+ Create Category"
                                android:textAllCaps="false"
                                android:fontFamily="@font/roboto_medium"
                                app:backgroundTint="@null" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- List Section -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginTop="@dimen/_8sdp"
                    tools:listitem="@layout/item_category_premium" />

                <!-- Add New Category Placeholder -->
                <FrameLayout
                    android:id="@+id/btnAddPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_80sdp"
                    android:layout_marginHorizontal="@dimen/_20sdp"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:background="@drawable/bg_dashed_border"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="@dimen/_24sdp"
                            android:layout_height="@dimen/_24sdp"
                            android:src="@drawable/ic_add"
                            app:tint="@color/stitch_on_surface_variant" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add New Category"
                            android:fontFamily="@font/roboto_medium"
                            android:textColor="@color/stitch_on_surface_variant"
                            android:layout_marginTop="@dimen/_8sdp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Category Health Summary Card -->

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
