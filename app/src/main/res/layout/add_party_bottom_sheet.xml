<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical">

    <!-- TITLE -->
    <TextView
        android:id="@+id/title_party"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Party"
        android:textColor="@color/text_color"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="10dp" />

    <!-- NAME -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Party Name"
        style="@style/GlassInput"
        app:hintTextColor="@color/text_color">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/party_name_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_color" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- PHONE -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Phone Number"
        style="@style/GlassInput"
        app:hintTextColor="@color/text_color">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/party_phone_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:textColor="@color/text_color" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- SAVE BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_party_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="26dp"
        android:text="Save"
        android:textAllCaps="false"
        android:textColor="@color/text_color"
        app:backgroundTint="@color/primary_color"
        style="@style/Widget.MaterialComponents.Button" />

    <!-- CANCEL -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancel_party_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_color"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>
