<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_20sdp"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:elevation="@dimen/_6sdp"
        android:clipToOutline="true">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Business"
        android:textSize="@dimen/_16ssp"
        android:fontFamily="@font/roboto_medium"
        android:textFontWeight="600"
        android:padding="@dimen/_16sdp"
        android:textColor="@color/text_color"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_business_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="@dimen/_400sdp"
        android:layout_marginBottom="@dimen/_8sdp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_add_new_business"
        android:layout_marginHorizontal="@dimen/_16sdp"
        android:textFontWeight="600"
        android:text="+ ADD NEW BUSINESS"
        android:padding="@dimen/_12sdp"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:layout_marginTop="@dimen/_24sdp"
        android:fontFamily="@font/roboto_bold"
        android:textSize="@dimen/_13ssp"
        android:textColor="@color/auth_bg"
        android:textAllCaps="false"
        android:elevation="@dimen/_16sdp"
        android:background="@drawable/bg_gradient_button"
        app:cornerRadius="@dimen/_12sdp"
        />

</LinearLayout>
</FrameLayout>