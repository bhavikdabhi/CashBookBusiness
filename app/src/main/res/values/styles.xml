<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GlassCard">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:clipToOutline">true</item>
    </style>

    <style name="PrimaryButton">
        <item name="android:backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="DangerButton">
        <item name="android:backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SuccessButton">
        <item name="android:backgroundTint">@color/success</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="GlassInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/card_bg</item>
        <item name="boxStrokeColor">@color/glass_border</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="GlassInput.ExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/card_bg</item>
        <item name="boxStrokeColor">@color/glass_border</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>


    <style name="PopupMenuTheme" parent="ThemeOverlay.Material3.Light">
        <item name="popupMenuBackground">@drawable/bg_popup_menu</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="iconTint">@color/text_secondary</item>
    </style>



    <style name="PopupMenuStyle.Custom" parent="Widget.Material3.PopupMenu">
        <item name="popupMenuBackground">@drawable/bg_popup_menu</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>


    <style name="PopupMenuItemText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="GlassSpinner">
        <item name="android:background">@drawable/bg_glass_field</item>
        <item name="android:padding">10dp</item>
        <item name="android:spinnerMode">dropdown</item>
        <item name="android:popupBackground">@color/card_bg</item>
    </style>

    <style name="GlassSpinnerItem">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="GlassSpinnerDropDownItem">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:padding">14dp</item>
        <item name="android:background">@color/card_bg</item>
    </style>

    <style name="CashbkAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@drawable/bg_popup_menu</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="colorPrimary">@color/primary_color</item>
    </style>

    <style name="PinKeypadButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">@dimen/_8sdp</item>
        <item name="android:background">@drawable/bg_keypad_button</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/_18ssp</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="PinKeypadButtonImage">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/_50sdp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">@dimen/_8sdp</item>
        <item name="android:background">@drawable/bg_keypad_button</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up_dialog</item>
        <item name="android:windowExitAnimation">@anim/slide_down_dialog</item>
    </style>

</resources>