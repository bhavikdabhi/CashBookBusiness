<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CashBookBusiness" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_color</item>

        <item name="android:fontFamily">@font/roboto_regular</item>
        <item name="android:textFontWeight">600</item>
        <!-- App Primary Colors -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_hover</item>
        <item name="colorOnPrimary">@color/text_secondary</item>

        <!-- Status bar / Nav bar -->
        <item name="android:statusBarColor">@color/bg_color</item>
        <item name="android:navigationBarColor">@color/bg_color</item>

        <!-- Default Text Color -->
        <item name="android:textColor">@color/text_secondary</item>

    </style>

    <style name="Theme.CashBookBusiness" parent="Base.Theme.CashBookBusiness">
        <item name="android:popupMenuStyle">@style/Widget.App.PopupMenu</item>
    </style>

    <!-- Glassmorphism Styles -->
    <style name="Widget.App.GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/stitch_surface_container_high</item>
        <item name="cardCornerRadius">@dimen/_12sdp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.App.Button.Gradient" parent="Widget.Material3.Button">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:background">@drawable/bg_primary_gradient</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/_24sdp</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>

    <style name="Widget.App.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupMenuStyle">@style/PopupMenuTheme</item>
    </style>

    <style name="Widget.App.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.App.BottomNav.Indicator</item>
        <item name="android:fontFamily">@font/roboto_regular</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="Widget.App.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedReceiptThumb" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

</resources>